aws_region   = "us-east-1"
aws_profile  = "YOUR_AWS_PROFILE"
environment  = "dev"
project_name = "sftp-external"

# Keycloak Configuration
keycloak_url           = "https://keycloak.example.com"
keycloak_realm         = "my-realm"
keycloak_client_id     = "aws-transfer-family"
keycloak_client_secret = "your-keycloak-client-secret"

sftp_users = {
  # Public keys are now managed in Keycloak. 
  # We only define the user and their home directory here to create the IAM role.
  "alice" = {
    home_directory = null # defaults to username
  }
  "bob" = {
    home_directory = "team-uploads"
  }
}

log_retention_days = 30
